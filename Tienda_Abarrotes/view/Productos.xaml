<Window x:Class="Tienda_Abarrotes.View.Productos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos"
        Height="600" Width="1000"
        Background="#F4F6F8">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <StackPanel Background="#0F7A2F" Grid.Column="0">
            <TextBlock Text="Aba-Inventory"
                       Foreground="White"
                       FontSize="20"
                       Margin="20"
                       FontWeight="Bold"/>

            <Button Content="Inicio" Margin="10"/>
            <Button Content="Productos" Margin="10"/>
            <Button Content="Categorias" Margin="10"/>
            <Button Content="Finanzas" Margin="10"/>
            <Button Content="Configuración" Margin="10"/>

            <Button Content="+ Agregar Producto"
                    Background="#1BBF4C"
                    Foreground="White"
                    Margin="10"
                    Height="40"/>
        </StackPanel>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Producto"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ListaProductos}"
                      AutoGenerateColumns="False"
                      RowHeight="60"
                      CanUserAddRows="False"
                      Background="White"
                      BorderThickness="0">

                <DataGrid.Columns>

                    <!-- Imagen -->
                    <DataGridTemplateColumn Header="Estado" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="5"
                    CornerRadius="10"
                    HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Estado}"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Nombre -->
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Nombre}"
                                        Width="*"/>

                    <!-- Estado -->
                    <DataGridTextColumn Header="Estado"
                                        Binding="{Binding Estado}"
                                        Width="120"/>

                    <!-- Stock -->
                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}"
                                        Width="100"/>

                    <!-- Categoria -->
                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding Categoria}"
                                        Width="150"/>

                </DataGrid.Columns>

            </DataGrid>
        </Grid>
    </Grid>
</Window>